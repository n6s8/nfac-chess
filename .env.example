# AlgoChess environment variables
# Copy this file to `.env` or `.env.local` and fill in your values.

# ─── Supabase ─────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Groq (AI explanations — single-player move analysis only) ───────────────
# NOTE: The Master Council debrief (LangGraph pipeline) now runs server-side
# via a Supabase Edge Function. Only the per-move explanation still uses this key.
# For full security, move this to an Edge Function too (see supabase/functions/).
VITE_GROQ_API_KEY=gsk-...

# ─── Stripe (Monetization) ────────────────────────────────────────────────────
# Publishable key — safe to expose in the browser
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Price ID for AlgoChess Pro ($4.99/mo) — create in Stripe Dashboard
VITE_STRIPE_PRICE_ID=price_...

# The following secrets MUST NOT be in this file — set them in Supabase Secrets:
#   supabase secrets set STRIPE_SECRET_KEY=sk_test_...
#   supabase secrets set STRIPE_WEBHOOK_SECRET=whsec_...
#   supabase secrets set GROQ_API_KEY=gsk_...

# ─── App settings ─────────────────────────────────────────────────────────────
VITE_STOCKFISH_DEPTH=15
VITE_BLUNDER_THRESHOLD=150
